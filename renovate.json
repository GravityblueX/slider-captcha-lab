{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Shanghai",
  "schedule": ["before 9am on monday"],
  "dependencyDashboard": true,
  "automerge": false,
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["pip_requirements", "pep621"],
      "groupName": "python diagnostics dependencies"
    },
    {
      "matchPackageNames": ["playwright"],
      "groupName": "browser automation diagnostics"
    },
    {
      "matchPackageNames": ["pyinstaller"],
      "groupName": "packaging toolchain"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ]
}
